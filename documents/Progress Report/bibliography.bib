@article{doi:10.1200/JCO.2016.34.15\_suppl.e18246,
author = {Flores, John Paul and Moreno-Koehler, Alejandro and Finkelman, Matthew and Caro, Jaime and Strauss, Gary M. },
title = {Comparative effectiveness of lung cancer screening by computed tomography (CT) vs. chest x-ray (CXR) vs. no screening.},
journal = {Journal of Clinical Oncology},
volume = {34},
number = {15\_suppl},
pages = {e18246-e18246},
year = {2016},
doi = {10.1200/JCO.2016.34.15\_suppl.e18246},

note ={PMID: },

URL = {https://ascopubs.org/doi/abs/10.1200/JCO.2016.34.15_suppl.e18246},
eprint = {https://ascopubs.org/doi/pdf/10.1200/JCO.2016.34.15_suppl.e18246}
,
abstract = { e18246Background: We sought to compare effectiveness of lung cancer screening by CXR vs. CT vs. no screening to facilitate a cost-effectiveness analysis. PLCO and NLST compared CXR vs. no screening, and CT vs. CXR respectively. If efficacious, CXR may be a cost-effective alternative to CT as it is associated with a lower false-positive rate and potentially lower costs. Methods: PLCO and NLST trial data were obtained from NCI. Lung cancer incidence was compared by Fisher’s exact test. Overall survival (OS) of those diagnosed with lung cancer was calculated in an intent-to-screen analysis using the Kaplan-Meier method and compared by log-rank test. To compare to NLST, analysis of PLCO was limited to lung cancers diagnosed up to 7 years after randomization. This also accounts for sojourn time as follow-up in PLCO was prolonged (12 years) compared to screening (3 years). As only NLST enrolled based on smoking history, the NLST-eligible subset of PLCO was analyzed. Results: In NLST (N = 52,234), 1089 and 969 lung cancers were detected in CT and CXR groups respectively (RR = 1.12; 95\%CI 1.03-1.22; p = 0.007). 5-year OS was superior with CT, 49\% vs. 33\% (p \&lt; 0.001). In PLCO (N = 150,835), 1072 and 1022 lung cancers were detected within 7 yrs of randomization in CXR and control groups, (RR = 1.05; CI 0.96-1.14; p = 0.27). 5-year OS was 27\% vs. 18\% (p \&lt; 0.001). In the NLST-eligible subset of PLCO (N = 30,321), within 7 years of randomization, 676 and 656 lung cancers were detected in the CXR and control groups (RR = 1.03; 95\% CI 0.92-1.14; p = 0.61). 5-year OS was superior with CXR, 25\% vs.18\% (p \&lt; 0.001). Conclusions: CT screening is superior to CXR, while CXR screening is superior to no screening. Incidence is not significantly increased with CXR compared to no screening arguing against overdiagnosis, though incidence is increased with CT. CXR survival in NLST is better than PLCO, possibly reflecting the effect of adjuvant chemotherapy. These survival differences are the basis of an ongoing cost-effectiveness analysis. While CT is superior to CXR screening, CXR is a widely accessible, inexpensive screening tool that can substantially reduce the global burden of lung cancer mortality, particularly where the costs of CT are prohibitive. }
}

